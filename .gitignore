.DS_Store

# Local tool/runtime caches
.ruff_cache/
.serena/
.claude/

# Python virtual/build caches
__pycache__/
*.pyc

# Xcode / build artifacts outside subprojects
ios/build/

# Tool output
.local/

# Large on-device model outputs (download / prepare locally)
nllb-600m-mobile/

# Android / RN local build caches
mobile/android/.gradle/
mobile/android/app/.cxx/
mobile/android/build/
mobile/android/app/src/main/assets/index.android.bundle

# Local packaged archives / embedded debug bundles
mobile.zip
mobile 2.zip
mobile/ios/main.jsbundle

# Large bundled model binaries (keep folder docs only)
mobile/assets/models/**/*.onnx
mobile/assets/models/**/*.model
mobile/assets/models/**/vocab.json
!mobile/assets/models/**/README.md

{
  "name": "vnpt/php-service",
  "type": "project",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "verify": [
      "@analyse",
      "@test"
    ]
  }
}
